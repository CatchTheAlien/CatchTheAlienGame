---
// src/pages/create-alien.astro
import Layout from '../layouts/Layout.astro';
import { ALIEN_TYPES } from '@/data/alien_types';
---

<Layout
  title="Crear Alien | CatchTheAlien"
  description="Crea tu propio alien y añade los datos para ocultarlo en el mapa."
  canonical={`${import.meta.env.SITE || import.meta.env.PUBLIC_SITE_URL || 'https://catchthealien.example'}/create-alien`}
  image="/imgs/aliens/realimages/create-alien.jpg"
  openGraph={{
    title: 'Crear Alien - Catch The Alien',
    type: 'website',
    description:
      'Formulario para crear un nuevo alien y obtener el QR para esconderlo en la ciudad.',
  }}
>
  <div class="min-h-screen bg-gray-900 text-white">
    <!-- Header -->
    <div class="border-b border-gray-800 bg-gray-900/50 backdrop-blur">
      <div class="mx-auto max-w-4xl px-6 py-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-gray-400 transition-colors hover:text-green-400"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          Volver al inicio
        </a>
      </div>
    </div>

    <div class="mx-auto max-w-4xl px-6 py-12">
      <!-- Title -->
      <div class="mb-12 text-center">
        <h1 class="mb-4 text-4xl font-bold text-white">Crear nuevo alien</h1>
        <p class="text-lg text-gray-400">
          Esconde un alien en el mapa para que otros lo encuentren
        </p>
      </div>

      <!-- Form -->
      <div class="rounded-2xl border border-gray-700 bg-gray-800 p-8">
        <form id="create-alien-form" class="space-y-8">
          <!-- Tipo de alien -->
          <div>
            <label for="type" class="mb-3 block text-sm font-medium text-gray-300">
              Tipo de alien <span class="text-red-400">*</span>
            </label>
            <select
              id="type"
              name="type"
              required
              class="w-full rounded-lg border border-gray-600 bg-gray-700 px-4 py-3 text-white placeholder-gray-400 focus:border-transparent focus:ring-2 focus:ring-green-500 focus:outline-none"
            >
              <option value="">Selecciona un tipo...</option>
              {ALIEN_TYPES.map((type) => <option value={type.slug}>{type.name}</option>)}
            </select>
          </div>
          <div id="alien-preview" class="mt-4 flex justify-center">
            <div
              class="relative aspect-square w-40 overflow-hidden rounded-xl border border-gray-600 bg-white bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] bg-size-[16px_16px]"
            >
              <img
                id="alien-preview-img"
                src="/imgs/Unknown_alien.png"
                alt=""
                class="h-full w-full object-cover"
              />
            </div>
          </div>
          <!-- Creador -->
          <div>
            <label for="created_by" class="mb-3 block text-sm font-medium text-gray-300">
              Tu nombre <span class="text-red-400">*</span>
            </label>
            <input
              type="text"
              id="created_by"
              name="created_by"
              placeholder="Ej: Juan Pérez"
              required
              class="w-full rounded-lg border border-gray-600 bg-gray-700 px-4 py-3 text-white placeholder-gray-400 focus:border-transparent focus:ring-2 focus:ring-green-500 focus:outline-none"
            />
          </div>

          <!-- Educación de flujo -->
          <div class="rounded-lg bg-gray-800 p-4 text-sm text-gray-300">
            Crea primero el alien y hazte con el enlace/QR. Imprime y pega el QR en la pieza,
            escóndelo y después vuelve al enlace para completar la ubicación y activar el alien.
          </div>

          <!-- Submit -->
          <button
            type="submit"
            id="submit-btn"
            class="flex w-full items-center justify-center gap-2 rounded-lg bg-green-600 px-6 py-4 font-semibold text-white transition-colors duration-200 hover:bg-green-500 disabled:cursor-not-allowed disabled:opacity-50"
          >
            <span id="btn-text">Crear alien</span>
            <div
              id="loading-spinner"
              class="hidden h-5 w-5 animate-spin rounded-full border-2 border-white border-t-transparent"
            >
            </div>
          </button>
        </form>

        <!-- Result -->
        <div id="result" class="mt-8 hidden rounded-lg border border-gray-600 bg-gray-700 p-6">
          <div class="text-center">
            <div class="mb-4 text-6xl">✅</div>
            <h3 class="mb-2 text-xl font-semibold text-green-400">¡Alien creado!</h3>
            <p class="mb-6 text-gray-300">
              Alien creado en modo "pendiente". Imprime el QR, pégalo en la pieza y esconde el
              alien. Luego vuelve al enlace para activar y publicar en el mapa.
            </p>

            <!-- Links -->
            <div class="space-y-4">
              <div>
                <p class="mb-2 text-sm text-gray-400">Enlace del alien:</p>
                <div class="flex gap-2">
                  <input
                    id="alien-url"
                    type="text"
                    readonly
                    class="flex-1 rounded border border-gray-500 bg-gray-600 px-3 py-2 text-sm text-white"
                  />
                  <button
                    onclick="copyToClipboard('alien-url')"
                    class="rounded bg-gray-600 px-4 py-2 text-sm text-white transition-colors hover:bg-gray-500"
                  >
                    Copiar
                  </button>
                </div>
              </div>

              <!-- QR Code -->
              <div>
                <p class="mb-2 text-sm text-gray-400">Código QR:</p>
                <div id="qr-container" class="flex justify-center">
                  <!-- QR will be generated here -->
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="mt-6 flex flex-wrap justify-center gap-3">
              <a
                id="view-alien-btn"
                href="#"
                class="rounded bg-green-600 px-4 py-2 text-sm text-white transition-colors hover:bg-green-500"
              >
                Ver alien
              </a>
              <button
                id="download-qr-btn"
                class="rounded bg-blue-600 px-4 py-2 text-sm text-white transition-colors hover:bg-blue-500 disabled:cursor-not-allowed disabled:opacity-50"
                disabled
                type="button"
              >
                Descargar QR
              </button>
              <button
                onclick="resetForm()"
                class="rounded bg-gray-600 px-4 py-2 text-sm text-white transition-colors hover:bg-gray-500"
                type="button"
              >
                Crear otro
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { ALIEN_TYPES } from '@/data/alien_types';
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  const alienTypes = ALIEN_TYPES as { slug: string; folder: string; name: string }[];

  // Form submission
  document.getElementById('create-alien-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    console.log('create-alien: submit');

    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text') as HTMLElement;
    const spinner = document.getElementById('loading-spinner') as HTMLElement;

    // Show loading
    submitBtn.disabled = true;
    btnText.textContent = 'Creando alien...';
    spinner.classList.remove('hidden');

    try {
      const formData = new FormData(e.target as HTMLFormElement);
      const type = (formData.get('type') || '').toString().trim();
      const name = (formData.get('name') || '').toString().trim();
      const created_by = (formData.get('created_by') || '').toString().trim();

      // Client-side validations
      if (!type) {
        alert('Selecciona un tipo de alien válido');
        return;
      }

      if (!created_by || created_by.length < 3 || created_by.length > 15) {
        alert('Tu nombre debe tener entre 3 y 15 caracteres');
        return;
      }

      if (name && (name.length < 3 || name.length > 15)) {
        alert('El nombre personalizado debe tener entre 3 y 15 caracteres');
        return;
      }

      const data = {
        type,
        name: name || null,
        created_by,
      };

      const response = await fetch('/api/create-alien', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();
      console.log('create-alien: response', result);

      if (result.success) {
        console.log('create-alien: alien created id', result.id);
        showResult(result.id);
      } else {
        throw new Error(result.error || 'Error al crear el alien');
      }
    } catch (error) {
      console.error('create-alien: Error:', error);
      alert('Error al crear el alien. Por favor, inténtalo de nuevo.');
    } finally {
      // Hide loading
      submitBtn.disabled = false;
      btnText.textContent = 'Crear alien';
      spinner.classList.add('hidden');
    }
  });

  let currentQrUrl: string | null = null;

  function showResult(alienId: string) {
    const baseUrl = window.location.origin;
    const alienUrl = `${baseUrl}/a/${alienId}`;

    // Update URL input
    (document.getElementById('alien-url') as HTMLInputElement).value = alienUrl;

    // Update view button
    (document.getElementById('view-alien-btn') as HTMLAnchorElement).href = `/a/${alienId}`;

    // Generate QR code
    generateQR(alienUrl);

    // Enable download button
    const downloadBtn = document.getElementById('download-qr-btn') as HTMLButtonElement;
    if (downloadBtn) {
      downloadBtn.disabled = false;
      downloadBtn.onclick = () => {
        if (currentQrUrl) {
          downloadQR(currentQrUrl);
        }
      };
    }

    // Show result
    document.getElementById('result')?.classList.remove('hidden');

    // Scroll to result
    document.getElementById('result')?.scrollIntoView({ behavior: 'smooth' });
  }

  function generateQR(url: string) {
    // Using a simple QR API - you might want to use a more robust solution
    const qrContainer = document.getElementById('qr-container');
    const qrApiUrl = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(url)}`;
    currentQrUrl = qrApiUrl;

    if (qrContainer) {
      qrContainer.innerHTML = `
        <img src="${qrApiUrl}"
             alt="QR Code"
             class="w-32 h-32 bg-white p-2 rounded" />
      `;
    }
  }

  async function downloadQR(qrUrl: string) {
    try {
      const response = await fetch(qrUrl);
      const blob = await response.blob();
      const objectUrl = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = objectUrl;
      a.download = `alien-qr-${Date.now()}.png`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(objectUrl);
    } catch (error) {
      console.error('Error downloading QR:', error);
      alert('No se pudo descargar el QR directamente. Prueba guardar la imagen manualmente.');
    }
  }

  // Global functions for buttons
  (window as any).copyToClipboard = (elementId: string) => {
    const element = document.getElementById(elementId) as HTMLInputElement;
    element.select();
    document.execCommand('copy');

    // Visual feedback
    const originalText = element.value;
    element.value = '¡Copiado!';
    setTimeout(() => {
      element.value = originalText;
    }, 1000);
  };

  (window as any).resetForm = () => {
    // Reset form
    (document.getElementById('create-alien-form') as HTMLFormElement).reset();

    // Hide result
    document.getElementById('result')?.classList.add('hidden');
  };

  document.getElementById('type')?.addEventListener('change', (e) => {
    const slug = (e.target as HTMLSelectElement).value;
    const preview = document.getElementById('alien-preview')!;
    const img = document.getElementById('alien-preview-img') as HTMLImageElement;

    if (!slug) {
      preview.classList.add('hidden');
      return;
    }

    const type = alienTypes.find((t) => t.slug === slug);
    if (type) {
      img.src = `/imgs/aliens/${type.folder}/0005.webp`;
      img.alt = `Alien tipo ${type.name}`;
      preview.classList.remove('hidden');
    }
  });
</script>

<style>
  .custom-alien-marker {
    background: none !important;
    border: none !important;
  }

  /* Dark theme for Leaflet controls */
  .leaflet-control-container .leaflet-control {
    background-color: rgba(31, 41, 55, 0.8) !important;
    color: white !important;
  }

  .leaflet-control-container .leaflet-control a {
    color: white !important;
  }

  .leaflet-control-container .leaflet-control a:hover {
    color: #10b981 !important;
  }
</style>
