---
// src/pages/a/[id].astro

import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import AlienCard from '../../components/AlienCard.astro';
import { getAlienById } from '../../lib/db';
import 'leaflet/dist/leaflet.css';

export const prerender = false;

const { id } = Astro.params;
const alien = await getAlienById(id as string);

if (!alien) {
  return Astro.redirect('/404');
}

if (alien.status === 'found') {
  return Astro.redirect(`/map?highlight=${id}`);
}

const isPending = alien.status === 'pending';
---

<Layout
  title={`Alien ${alien.codename} | CatchTheAlien`}
  description={`Detalles del alien ${alien.codename}, estado ${alien.status} y opciones para activar o reclamar.`}
  canonical={`${import.meta.env.SITE || import.meta.env.PUBLIC_SITE_URL || 'https://catchthealien.example'}/a/${alien.id}`}
  image={alien.image_url || '/imgs/aliens/realimages/detail.jpg'}
  openGraph={{
    title: `Alien ${alien.codename} - Catch The Alien`,
    type: 'website',
    description: `Ver información y estado del alien ${alien.codename}`,
  }}
  }
>
  <Navbar />
  <section class="bg-bg-primary min-h-screen px-4 py-16">
    <div class="h-10"></div>
    <div class="mx-auto max-w-2xl">
      {
        isPending ? (
          <div class="bg-bg-secondary rounded-2xl border border-(--color-border) p-8">
            <div class="mb-6 text-center">
              <div class="mb-4 text-6xl">👽</div>
              <h1 class="text-text-primary mb-2 text-3xl font-bold">Alien listo para activarse</h1>
              <p class="text-text-muted">
                Has creado el alien: <strong>{alien.codename}</strong>. Imprime el QR y esconde la
                pieza primero. Luego completa la ubicación y activa para que aparezca en el mapa.
              </p>
            </div>

            <form id="activate-alien-form" class="space-y-6">
              <div>
                <label class="text-text-primary text-sm font-medium">
                  Ubicación (latitud/longitud)
                </label>
                <div id="activate-map" class="mt-2 h-64 w-full rounded-lg border border-gray-600" />
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label for="lat" class="text-xs text-gray-400">
                    Latitud
                  </label>
                  <input
                    id="lat"
                    name="location_lat"
                    type="number"
                    step="0.000001"
                    class="mt-1 w-full rounded border border-gray-600 bg-gray-700 px-3 py-2 text-sm text-white"
                    required
                  />
                </div>
                <div>
                  <label for="lng" class="text-xs text-gray-400">
                    Longitud
                  </label>
                  <input
                    id="lng"
                    name="location_lng"
                    type="number"
                    step="0.000001"
                    class="mt-1 w-full rounded border border-gray-600 bg-gray-700 px-3 py-2 text-sm text-white"
                    required
                  />
                </div>
              </div>

              <div>
                <label for="hidden-photo" class="text-text-primary text-sm font-medium">
                  Foto del alien escondido (recomendado)
                </label>
                <input
                  id="hidden-photo"
                  name="hidden_photo"
                  type="file"
                  accept="image/*"
                  class="mt-2 w-full rounded-lg border border-gray-600 bg-gray-700 px-3 py-2 text-sm text-white"
                />
                <p class="mt-1 text-xs text-gray-400">
                  Sube una foto de la ubicación del alien para mejor control y futura vista.
                </p>
              </div>

              <button
                type="submit"
                id="activate-btn"
                class="w-full rounded-lg bg-green-600 px-4 py-3 font-semibold text-white hover:bg-green-500"
              >
                Activar alien y esconder
              </button>
            </form>

            <div id="activation-status" class="mt-4 hidden text-center text-sm text-green-400" />
          </div>
        ) : (
          <>
            <div class="bg-bg-secondary mb-8 rounded-2xl border border-(--color-border) p-8">
              <div class="text-center">
                <div class="mb-4 text-6xl">👽</div>
                <h1 class="text-text-primary mb-2 text-3xl font-bold">
                  {`Alien #${alien.codename}`}
                </h1>
                <p class="text-text-muted mb-6">
                  Tipo: {alien.type} • Escondido{' '}
                  {new Date(alien.created_at * 1000).toLocaleDateString('es-ES')}
                </p>
                <div class="flex justify-center gap-4">
                  <button
                    id="claim-btn"
                    class="inline-block rounded-lg bg-green-600 px-6 py-3 font-semibold text-white hover:bg-green-500"
                  >
                    Reclamar
                  </button>
                </div>
              </div>
            </div>
            <div id="claim-modal" class="bg-opacity-50 fixed inset-0 z-50 hidden bg-black">
              <div class="bg-bg-secondary mx-4 mt-20 w-full max-w-md rounded-2xl p-8">
                <h3 class="text-text-primary mb-4 text-xl font-bold">Reclamar alien</h3>
                <p class="text-text-secondary mb-6">
                  ¡Felicidades! Has encontrado este alien. Introduce tu nombre para reclamarlo.
                </p>
                <form id="claim-form">
                  <div class="mb-4">
                    <label for="claimer-name" class="text-text-primary text-sm font-medium">
                      Tu nombre
                    </label>
                    <input
                      id="claimer-name"
                      name="name"
                      type="text"
                      placeholder="Ej: Juan Pérez"
                      class="mt-2 w-full rounded-lg border border-gray-600 bg-gray-700 px-4 py-2 text-white"
                      required
                    />
                  </div>
                  <div class="flex gap-4">
                    <button
                      type="button"
                      id="cancel-claim"
                      class="flex-1 rounded-lg bg-gray-600 px-4 py-2 font-semibold text-white hover:bg-gray-500"
                    >
                      Cancelar
                    </button>
                    <button
                      type="submit"
                      class="flex-1 rounded-lg bg-green-600 px-4 py-2 font-semibold text-white hover:bg-green-500"
                    >
                      Reclamar
                    </button>
                  </div>
                </form>
                <div id="claim-status" class="mt-4 hidden text-center text-sm text-green-400" />
              </div>
            </div>

            <div class="bg-bg-secondary rounded-2xl border border-(--color-border) p-8">
              <h2 class="text-text-primary mb-4 text-xl font-semibold">
                ¿Cómo reclamar este alien?
              </h2>
              <ol class="text-text-secondary space-y-3">
                <li class="flex items-start gap-3">
                  <span class="text-bg-primary mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-(--color-accent-primary) text-sm font-semibold">
                    1
                  </span>
                  <span>Escanea el QR pegado en el alien para llegar aquí</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-bg-primary mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-(--color-accent-primary) text-sm font-semibold">
                    2
                  </span>
                  <span>Haz click en "Reclamar" e introduce tu nombre</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-bg-primary mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-(--color-accent-primary) text-sm font-semibold">
                    3
                  </span>
                  <span>¡Ya es tuyo! Aparecerá en tu lista de aliens encontrados</span>
                </li>
              </ol>
            </div>
          </>
        )
      }
    </div>
  </section>
</Layout>

<!-- 
  IMPORTANTE: define:vars no permite import statements.
  Los datos del servidor se inyectan como variables globales mediante define:vars,
  y los imports de módulos van en un <script> separado normal.
-->

<!-- Paso 1: inyectar datos del servidor como variables globales -->
<script define:vars={{ alien, isPending }}>
  // Estas variables quedan disponibles en el scope global de la página
  window.__alienData = alien;
  window.__isPending = isPending;
</script>

<!-- Paso 2: lógica del cliente con imports normales -->
<script>
  import L from 'leaflet';

  // Fix para los iconos por defecto de Leaflet con bundlers (Vite/Astro)
  import markerIcon2x from 'leaflet/dist/images/marker-icon-2x.png';
  import markerIcon from 'leaflet/dist/images/marker-icon.png';
  import markerShadow from 'leaflet/dist/images/marker-shadow.png';

  // @ts-ignore
  delete L.Icon.Default.prototype._getIconUrl;
  L.Icon.Default.mergeOptions({
    iconUrl: markerIcon.src,
    iconRetinaUrl: markerIcon2x.src,
    shadowUrl: markerShadow.src,
  });

  function toBase64(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        if (typeof reader.result === 'string') resolve(reader.result);
        else reject(new Error('No se pudo convertir el archivo.'));
      };
      reader.onerror = (error) => reject(error);
      reader.readAsDataURL(file);
    });
  }

  function getBase64Size(dataUrl: string) {
    const base64 = dataUrl.split(',')[1] || '';
    const padding = base64.endsWith('==') ? 2 : base64.endsWith('=') ? 1 : 0;
    return Math.ceil((base64.length * 3) / 4 - padding);
  }

  function validateImageDimensions(dataUrl: string) {
    return new Promise<boolean>((resolve, reject) => {
      const img = new Image();
      img.onload = () => {
        if (img.width <= 1920 && img.height <= 1920) {
          resolve(true);
        } else {
          resolve(false);
        }
      };
      img.onerror = () => reject(new Error('No se pudo comprobar las dimensiones de la imagen.'));
      img.src = dataUrl;
    });
  }

  function supportsWebP(): boolean {
    const canvas = document.createElement('canvas');
    canvas.width = 1;
    canvas.height = 1;
    return canvas.toDataURL('image/webp').indexOf('data:image/webp') === 0;
  }

  async function resizeImage(file: File): Promise<string> {
    const dataUrl = await toBase64(file);
    const img = new Image();

    await new Promise<void>((resolve, reject) => {
      img.onload = () => resolve();
      img.onerror = () => reject(new Error('No se pudo cargar la imagen para resize.'));
      img.src = dataUrl;
    });

    const maxDimension = 1920;
    let targetWidth = img.naturalWidth;
    let targetHeight = img.naturalHeight;

    let initialScale = Math.min(1, maxDimension / targetWidth, maxDimension / targetHeight);
    targetWidth = Math.max(1, Math.round(targetWidth * initialScale));
    targetHeight = Math.max(1, Math.round(targetHeight * initialScale));

    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    if (!ctx) throw new Error('No se pudo obtener contexto de canvas.');

    const minDimension = 320;
    let candidate = '';

    const outputType = supportsWebP() ? 'image/webp' : 'image/jpeg';

    while (true) {
      canvas.width = targetWidth;
      canvas.height = targetHeight;
      ctx.clearRect(0, 0, targetWidth, targetHeight);
      ctx.drawImage(img, 0, 0, targetWidth, targetHeight);

      let quality = 0.92;
      candidate = canvas.toDataURL(outputType, quality);

      while (getBase64Size(candidate) > 1024 * 1024 && quality > 0.35) {
        quality = Math.max(0.35, quality - 0.07);
        candidate = canvas.toDataURL(outputType, quality);
      }

      if (getBase64Size(candidate) <= 1024 * 1024) {
        return candidate;
      }

      if (targetWidth <= minDimension || targetHeight <= minDimension) {
        break;
      }

      targetWidth = Math.max(minDimension, Math.round(targetWidth * 0.9));
      targetHeight = Math.max(minDimension, Math.round(targetHeight * 0.9));
    }

    throw new Error(
      'No fue posible ajustar la imagen a 1MB. Usa una imagen más pequeña o con menor resolución.'
    );
  }

  function initActivateAlien() {
    // Recuperar los datos inyectados por define:vars
    const alien = (window as any).__alienData;
    const isPending = (window as any).__isPending;

    if (!isPending) {
      return;
    }

    console.log('activate-alien: page loaded (pending) id', alien.id);

    const mapEl = document.getElementById('activate-map');
    if (!mapEl) return;

    const map = L.map('activate-map').setView([43.263, -2.935], 13);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors © CARTO',
      maxZoom: 18,
    }).addTo(map);

    // Intentar geolocalización; si deniega, se queda en Bilbao
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (pos) => map.setView([pos.coords.latitude, pos.coords.longitude], 15),
        () => {}
      );
    }

    const latInput = document.getElementById('lat') as HTMLInputElement;
    const lngInput = document.getElementById('lng') as HTMLInputElement;

    let marker: L.Marker | null = null;

    // Click en el mapa → coloca/mueve el marcador
    map.on('click', (e: L.LeafletMouseEvent) => {
      const { lat, lng } = e.latlng;
      console.log('activate-alien: map click', { lat, lng });

      if (marker) map.removeLayer(marker);
      marker = L.marker([lat, lng]).addTo(map);

      latInput.value = lat.toFixed(6);
      lngInput.value = lng.toFixed(6);
    });

    // Submit del formulario
    const activateForm = document.getElementById('activate-alien-form');
    activateForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      console.log('activate-alien: submit', { id: alien.id });

      const location_lat = parseFloat((document.getElementById('lat') as HTMLInputElement).value);
      const location_lng = parseFloat((document.getElementById('lng') as HTMLInputElement).value);

      const fileInput = document.getElementById('hidden-photo') as HTMLInputElement;
      let imageData: string | null = null;

      if (fileInput?.files?.length) {
        const file = fileInput.files[0];
        console.log('activate-alien: file selected', file.name, file.type, file.size);

        try {
          const candidate = await resizeImage(file);
          const sizeBytes = getBase64Size(candidate);
          if (sizeBytes > 1024 * 1024) {
            alert(
              'No fue posible reducir la imagen por debajo de 1MB. Usa una imagen más pequeña.'
            );
            return;
          }
          imageData = candidate;
        } catch (err) {
          console.error('activate-alien: imagen no válida', err);
          alert(err instanceof Error ? err.message : 'Error procesando la imagen.');
          return;
        }
      }

      if (Number.isNaN(location_lat) || Number.isNaN(location_lng)) {
        alert('Selecciona una ubicación válida en el mapa.');
        return;
      }

      try {
        console.log('activate-alien: body params', {
          location_lat,
          location_lng,
          hasImage: !!imageData,
        });
        const response = await fetch('/api/activate-alien', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: alien.id,
            location_lat,
            location_lng,
            image_data: imageData,
          }),
        });

        const result = await response.json();
        console.log('activate-alien: response', result);

        if (result.success) {
          console.log('activate-alien: success', result);
          const statusEl = document.getElementById('activation-status');
          if (statusEl) {
            statusEl.textContent = 'Alien activado con éxito. Ahora aparece en el mapa.';
            statusEl.classList.remove('hidden');
          }
          setTimeout(() => {
            window.location.reload();
          }, 1400);
        } else {
          console.warn('activate-alien: failed', result);
          alert('Error al activar el alien: ' + (result.error || 'Error desconocido'));
        }
      } catch (err) {
        console.error('activate-alien: error', err);
        alert('Error al activar el alien. Por favor, inténtalo más tarde.');
      }
    });
  }

  function initClaimAlien() {
    // Recuperar los datos inyectados por define:vars
    const alien = (window as any).__alienData;
    const isPending = (window as any).__isPending;

    if (isPending) {
      return;
    }

    console.log('claim-alien: page loaded (hidden) id', alien.id);

    const claimBtn = document.getElementById('claim-btn');
    const claimModal = document.getElementById('claim-modal');
    const cancelBtn = document.getElementById('cancel-claim');
    const claimForm = document.getElementById('claim-form');
    const claimStatus = document.getElementById('claim-status');

    if (!claimBtn || !claimModal || !cancelBtn || !claimForm) return;

    // Mostrar modal
    claimBtn.addEventListener('click', () => {
      claimModal.classList.remove('hidden');
      claimModal.classList.add('flex', 'items-center', 'justify-center');
    });

    // Ocultar modal
    cancelBtn.addEventListener('click', () => {
      claimModal.classList.add('hidden');
      claimModal.classList.remove('flex', 'items-center', 'justify-center');
      claimStatus.classList.add('hidden');
    });

    // Submit del formulario de reclamo
    claimForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const nameInput = document.getElementById('claimer-name') as HTMLInputElement;
      const foundBy = nameInput.value.trim();

      if (!foundBy) {
        alert('Por favor, introduce tu nombre.');
        return;
      }

      try {
        console.log('claim-alien: submit', { id: alien.id, foundBy });
        const response = await fetch('/api/claim-alien', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: alien.id,
            found_by: foundBy,
          }),
        });

        const result = await response.json();
        console.log('claim-alien: response', result);

        if (result.success) {
          console.log('claim-alien: success', result);
          claimStatus.textContent = '¡Alien reclamado con éxito! Redirigiendo...';
          claimStatus.classList.remove('hidden');
          setTimeout(() => {
            window.location.href = '/map?highlight=' + alien.id;
          }, 2000);
        } else {
          console.warn('claim-alien: failed', result);
          claimStatus.textContent = 'Error: ' + (result.error || 'Error desconocido');
          claimStatus.classList.remove('hidden');
          claimStatus.classList.add('text-red-400');
          claimStatus.classList.remove('text-green-400');
        }
      } catch (err) {
        console.error('claim-alien: error', err);
        claimStatus.textContent = 'Error al reclamar el alien. Inténtalo más tarde.';
        claimStatus.classList.remove('hidden');
        claimStatus.classList.add('text-red-400');
        claimStatus.classList.remove('text-green-400');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initActivateAlien();
      initClaimAlien();
    });
  } else {
    initActivateAlien();
    initClaimAlien();
  }
</script>
