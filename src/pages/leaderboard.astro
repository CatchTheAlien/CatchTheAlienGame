---
// src/pages/leaderboard.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import {
  getLeaderboard,
  getTotalFoundCount,
  getUniqueClaimersCount,
  getLastClaimer,
} from '@/lib/db';

const rawEntries = await getLeaderboard();
const totalClaims = await getTotalFoundCount();
const uniqueClaimers = await getUniqueClaimersCount();
const lastClaimer = await getLastClaimer();

// Función para formatear timestamp a fecha legible
function formatDate(timestamp: number): string {
  return new Date(timestamp * 1000).toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}

// Función para calcular y formatear el tiempo de claim
function formatClaimTime(createdAt: number, foundAt: number): string {
  const diffMs = (foundAt - createdAt) * 1000; // convertir a ms
  const diffMins = Math.floor(diffMs / (1000 * 60));
  const diffHours = Math.floor(diffMins / 60);
  const diffDays = Math.floor(diffHours / 24);

  if (diffDays > 0) return `${diffDays}d ${diffHours % 24}h`;
  if (diffHours > 0) return `${diffHours}h ${diffMins % 60}m`;
  if (diffMins > 0) return `${diffMins}m`;
  return '< 1m';
}

// Mapear los datos a la interfaz esperada por el template
const entries = rawEntries.map((entry) => ({
  rank: entry.rank,
  title: entry.codename,
  claimedDate: formatDate(entry.found_at),
  claimedBy: entry.found_by,
  claimTime: formatClaimTime(entry.created_at, entry.found_at),
  imageUrl: entry.image_url || undefined,
}));
---

<Layout
  title="Ranking de Aliens | CatchTheAlien"
  description="Los 15 jugadores más rápidos en encontrar aliens, ordenados por tiempo de hallazgo."
  canonical={`${import.meta.env.SITE || import.meta.env.PUBLIC_SITE_URL || 'https://catchthealien.example'}/leaderboard`}
  image="/imgs/aliens/realimages/leaderboard.jpg"
  openGraph={{
    title: 'Leaderboard - Catch The Alien',
    type: 'website',
    description: 'Ranking de los mejores buscadores de aliens en Catch The Alien.',
  }}
>
  <Navbar />
  <section class="bg-bg-primary min-h-screen px-4 py-16">
    <div class="mx-auto max-w-3xl">
      <!-- Header -->
      <div class="mb-10">
        <h1 class="text-text-primary text-3xl font-semibold tracking-tight">Hall of fame</h1>
        <p class="text-text-muted mt-1 text-sm">Los mas rapidos en encontrar a los aliens.</p>
      </div>

      <!-- Stats -->
      <div class="mb-8 grid grid-cols-3 gap-3">
        <div class="bg-bg-secondary rounded-xl border border-(--color-border) px-4 py-3">
          <p class="text-text-muted text-[10px] font-medium tracking-widest uppercase">
            Total claims
          </p>
          <p class="mt-1 font-mono text-2xl font-semibold text-(--color-accent-primary)">
            {totalClaims}
          </p>
        </div>
        <div class="bg-bg-secondary rounded-xl border border-(--color-border) px-4 py-3">
          <p class="text-text-muted text-[10px] font-medium tracking-widest uppercase">
            Claimers únicos
          </p>
          <p class="mt-1 font-mono text-2xl font-semibold text-(--color-accent-primary)">
            {uniqueClaimers}
          </p>
        </div>
        <div class="bg-bg-secondary rounded-xl border border-(--color-border) px-4 py-3">
          <p class="text-text-muted text-[10px] font-medium tracking-widest uppercase">
            Último claim
          </p>
          <p class="text-text-primary mt-1.5 truncate text-sm font-medium">
            {lastClaimer || 'N/A'}
          </p>
        </div>
      </div>

      <!-- Table -->
      <div class="bg-bg-secondary overflow-hidden rounded-xl border border-(--color-border)">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-(--color-border) bg-(--color-bg-tertiary)">
              <th
                class="text-text-muted w-14 px-5 py-3 text-center text-[10px] font-medium tracking-widest uppercase"
                >#</th
              >
              <th
                class="text-text-muted px-4 py-3 text-left text-[10px] font-medium tracking-widest uppercase"
                >Título</th
              >
              <th
                class="text-text-muted hidden px-4 py-3 text-left text-[10px] font-medium tracking-widest uppercase sm:table-cell"
                >Fecha</th
              >
              <th
                class="text-text-muted hidden px-4 py-3 text-left text-[10px] font-medium tracking-widest uppercase sm:table-cell"
                >Tiempo</th
              >
              <th
                class="text-text-muted px-4 py-3 text-left text-[10px] font-medium tracking-widest uppercase"
                >Reclamado por</th
              >
            </tr>
          </thead>
          <tbody>
            {
              entries.map((entry, i) => (
                <tr class="border-b border-(--color-border) transition-colors duration-100 last:border-0 hover:bg-(--color-bg-tertiary)">
                  <td class="px-5 py-4 text-center">
                    {i === 0 && (
                      <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-yellow-400/10 font-mono text-xs font-semibold text-yellow-400">
                        1
                      </span>
                    )}
                    {i === 1 && (
                      <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-slate-400/10 font-mono text-xs font-semibold text-slate-400">
                        2
                      </span>
                    )}
                    {i === 2 && (
                      <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-orange-400/10 font-mono text-xs font-semibold text-orange-400">
                        3
                      </span>
                    )}
                    {i > 2 && <span class="text-text-muted font-mono text-xs">{entry.rank}</span>}
                  </td>

                  <td class="px-4 py-4">
                    <div class="flex items-center gap-3">
                      <span class="text-text-primary font-medium">{entry.title}</span>
                    </div>
                  </td>

                  <td class="hidden px-4 py-4 sm:table-cell">
                    <span class="text-text-muted font-mono text-xs">{entry.claimedDate}</span>
                  </td>

                  <td class="hidden px-4 py-4 sm:table-cell">
                    <span class="font-mono text-xs text-(--color-accent-primary)">
                      {entry.claimTime}
                    </span>
                  </td>
                  <td class="px-4 py-4 sm:table-cell">
                    <span class="text-accent-soft font-mono text-xs">{entry.claimedBy}</span>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>
</Layout>
