---
import '../styles/global.css';
import '@fontsource/inter';
import '@fontsource/space-mono';

import SEO from '@/components/SEO.astro';
import type { Preload } from '@/types/Preload';

interface Props {
  title: string;
  description?: string;
  preload?: Array<Preload>;
  canonical?: string;
  image?: string;
  openGraph?: {
    title: string;
    type: string;
    description: string;
  };
}

const { title, description, preload, canonical, image, openGraph } = Astro.props;

const siteBaseUrl =
  import.meta.env.SITE || import.meta.env.PUBLIC_SITE_URL || 'https://catchthealien.example';
const pageCanonical = canonical || siteBaseUrl;
---

<!-- TODO: Añadir preload para no tener saltos de carga de fuente --><!doctype html>
<html lang="es">
  <head>
    <SEO
      title={title}
      description={description ?? 'Descubre y reclama aliens escondidos en tu ciudad'}
      image={image}
      canonical={pageCanonical}
      preload={preload}
      openGraph={openGraph}
    />
  </head>
  <body class="min-h-screen bg-white">
    <slot />
  </body>
</html>

<style is:global>
  @import 'tailwindcss';
  :root {
    --primary-color: #8ae67b;
  }
  html {
    font-family: 'Inter Variable', sans-serif;
    background: var(--bg-primary);
    background-size: 224px;
    height: 100%;
  }
  img {
    pointer-events: none;
  }

  p {
    line-height: 1.4;
    font-weight: medium;
    font-size: 1rem;
  }

  h1 {
    margin-top: 2rem;
    margin-bottom: 2rem;
    font-weight: bold;
    font-size: 3rem;
    line-height: 1.1;
    text-align: center;
    position: relative;
    color: var(--primary-color);
    font-family: 'Space Mono', monospace;
  }

  h2 {
    margin-top: 2rem;
    margin-bottom: 2rem;
    font-weight: bold;
    font-size: 2.25rem;
    line-height: 2.5rem;
    text-align: center;
    position: relative;
    color: var(--primary-color);
    font-family: 'Space Mono', monospace;
  }
  h3 {
    margin-top: 1rem;
    margin-bottom: 1rem;
    font-weight: bold;
    font-size: 1.25rem;
    line-height: 1.75rem;
    text-align: center;
    position: relative;
    color: var(--primary-color);
    font-family: 'Space Mono', monospace;
  }

  @media (max-width: 768px) {
    h2 {
      font-size: 1.75rem; /* Tamaño de fuente para dispositivos móviles */
      line-height: 2rem;
    }
  }
  @media (max-width: 480px) {
    h2 {
      font-size: 1.5rem; /* Tamaño de fuente para pantallas aún más pequeñas */
      line-height: 1.75rem;
    }
  }
</style>
